      "id": 12,
      "options": {
        "legend": {
          "calcs": ["mean", "last"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum by (controller) (rate(controller_runtime_reconcile_total{namespace=\"${namespace}\", result=\"error\"}[$__rate_interval]))",
          "legendFormat": "{{controller}}",
          "refId": "A"
        }
      ],
      "title": "Error Rate by Controller",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
