      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (controller, le) (rate(controller_runtime_reconcile_time_seconds_bucket{namespace=\"${namespace}\"}[$__rate_interval])))",
          "legendFormat": "{{controller}}",
          "refId": "A"
        }
      ],
      "title": "P99 Reconcile Duration by Controller",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
