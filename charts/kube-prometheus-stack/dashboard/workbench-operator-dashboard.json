          "expr": "sum by (controller) (rate(controller_runtime_reconcile_time_seconds_sum{namespace=\"${namespace}\"}[$__rate_interval])) / sum by (controller) (rate(controller_runtime_reconcile_time_seconds_count{namespace=\"${namespace}\"}[$__rate_interval]))",
          "legendFormat": "{{controller}}",
          "refId": "A"
        }
      ],
      "title": "Average Reconcile Duration by Controller",
      "type": "timeseries"
